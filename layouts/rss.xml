{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0"
     xmlns:atom="http://www.w3.org/2005/Atom"
     xmlns:content="http://purl.org/rss/1.0/modules/content/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:media="http://search.yahoo.com/mrss/">
  <channel>
    <title>{{ if eq .Title site.Title }}{{ site.Title }}{{ else }}{{ .Title }} | {{ site.Title }}{{ end }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ site.Params.description }}</description>
    <language>{{ site.LanguageCode | default "en-US" }}</language>
    <copyright>© {{ now.Format "2006" }} Arenar Intelligence. All rights reserved.</copyright>
    <lastBuildDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</lastBuildDate>
    <generator>Hugo</generator>

    <image>
      <url>{{ absURL site.Params.logo }}</url>
      <title>{{ site.Title }}</title>
      <link>{{ site.BaseURL }}</link>
      <width>512</width>
      <height>512</height>
    </image>

    <atom:link href="{{ .Permalink }}index.xml" rel="self" type="application/rss+xml" />

    {{ range first 50 (where site.RegularPages "Section" "intel").ByPublishDate.Reverse }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
      <guid isPermaLink="true">{{ .Permalink }}</guid>
      <dc:creator>{{ .Params.author | default "The Intel Desk" }}</dc:creator>
      <description>{{ with .Params.summary }}{{ . | html }}{{ else }}{{ .Summary | html }}{{ end }}</description>
      {{ with .Params.image }}
      <media:content url="{{ absURL . }}" medium="image" />
      <enclosure url="{{ absURL . }}" type="image/jpeg" />
      {{ end }}
<content:encoded>{{ printf "<![CDATA[%s]]>" .Content | safeHTML }}</content:encoded>    </item>
    {{ end }}
  </channel>
</rss>